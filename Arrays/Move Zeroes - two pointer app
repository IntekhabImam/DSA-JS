/**
 * @param {number[]} nums
 * @return {void} Do not return anything, modify nums in-place instead.
 */
var moveZeroes = function(nums) {
    let x = 0;

    for(let i =0; i<nums.length; i++){
        if(nums[i] !== 0){
            nums[x] = nums[i];
            x++;
        }
    }
    for(let i = x; i<nums.length; i++){
        nums[i] = 0;
    }
};


// Move Zeroes (LeetCode 283)
// Pattern: Two Pointers
// Idea: Move all non-zero elements to the front, then fill remaining positions with 0.
// Pointer x: Tracks the next position for a non-zero element.

