/**
 * @param {number[]} nums
 * @return {number}
 */
var missingNumber = function(nums) {
    let n = nums.length;
    let totalSum = n * (n+1) /2;

    partialSum = 0
    for(let i=0; i<n; i++){
        partialSum = partialSum + nums[i];
    }
    return totalSum - partialSum;
};

// Algorithm:

// Find n = nums.length.
// Compute totalSum = n * (n + 1) / 2.
// Traverse array and calculate partialSum.
// Return totalSum - partialSum.

// Complexity:

// Time: O(n)
// Space: O(1)
